# OpenAI API Settings
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith Tracing Settings
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
# Optional for org-scoped/private prompt sync when the SDK requires an explicit workspace header
LANGSMITH_WORKSPACE_ID=
LANGCHAIN_PROJECT=ai-agent-rag

# PostgreSQL DB Settings
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=rag_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Phase 2.5: Hybrid Search Settings
HYBRID_ALPHA=0.6
RETRIEVE_K_VECTOR=30
RETRIEVE_K_KEYWORD=30

# Phase 2.5: Dynamic TopK Settings
TOP_K_MIN=3
TOP_K_MAX=8

# Phase 2.5: Stage Timeout Settings (milliseconds)
STAGE_TIMEOUT_MS_REWRITE=3000
STAGE_TIMEOUT_MS_HYBRID=5000
STAGE_TIMEOUT_MS_COMPRESS=5000

# Phase 3: Agentic Retrieval Settings
ENABLE_AGENTIC=true
ENABLE_RERANK=false
ANSWER_CRITIC=true
ANSWER_CRITIC_RETRY=false
MAX_RETRY=3
MAX_SUB_QUERIES=4
MAX_MERGED_CHUNKS=20
STAGE_TIMEOUT_MS_ROUTER=1800
ROUTER_BUDGET_MS=500
ROUTER_UNCERTAIN_CONFIDENCE_CAP_PCT=80
PROMPT_LOAD_TIMEOUT_MS=1200
PROMPT_FAILURE_TTL_MS=30000
PREWARM_FAIL_FAST=true
STAGE_TIMEOUT_MS_RETRIEVAL_CRITIC=2500
STAGE_TIMEOUT_MS_ANSWER_CRITIC=2500
STAGE_TIMEOUT_MS_DECOMPOSE=1800
STAGE_TIMEOUT_MS_REWRITE_SUBQUERY=1800
STAGE_TIMEOUT_MS_RERANK=2500
COMPLEX_BUDGET_MS_LOW=4000
COMPLEX_BUDGET_MS_MEDIUM=7000
COMPLEX_BUDGET_MS_HIGH=9000
RETRIEVAL_DEGRADE_THRESHOLD_MS=2000
FORCE_GENERATE_THRESHOLD_MS=1500
RETRIEVAL_CRITIC_SKIP_CONFIDENCE_PCT=85
ANSWER_CRITIC_SKIP_CONFIDENCE_PCT=80
COHERE_API_KEY=
PROMPT_NAMESPACE=my-rag
